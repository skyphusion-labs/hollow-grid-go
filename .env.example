# Copy to .env and fill in for federation. Leave GRID_* unset for standalone play.

WORLD_NAME=Rust Choir
# Public WebSocket URL advertised to the Grid registry (travel handoff).
WORLD_URL=wss://rustchoir.skyphusion.org/ws

# Grid Hub HTTP RPC (deploy the-hollow-grid feat/grid-hub-http-rpc first).
GRID_HUB_URL=https://grid-hub.example/rpc
GRID_HUB_TOKEN=

# Optional overrides (defaults match compose.yaml)
# LISTEN_ADDR=:8790
# DATA_DIR=/data
# ADMINS=skyphusion
